NAVER_BLOG_ID=doorgeneral
CHROME_PATH=C:\Program Files\Google\Chrome\Application\chrome.exe

# Naver Search API for TOP10 analysis.
NAVER_CLIENT_ID=your_naver_client_id
NAVER_CLIENT_SECRET=your_naver_client_secret

# Naver Search Ad API for keyword demand.
NAVER_AD_API_KEY=your_ad_api_key
NAVER_AD_SECRET_KEY=your_ad_secret_key
NAVER_AD_CUSTOMER_ID=your_ad_customer_id

# Optional throttle override for ranking tracking.
TRACKING_DELAY_MS=2000
